# --- Production build (required for `npm run build`) ---
# Vite embeds VITE_* at build time. Set these in your CI/hosting env, then rebuild.
#
# Full URL of your API (Express). "/api" is appended if you pass only the origin
# (e.g. https://api.example.com → https://api.example.com/api).
# Must be set for production builds or api.ts will throw at startup.
VITE_API_URL=

# --- Firebase (optional; needed for forgot-password email flow & Firebase login fallback) ---
# All values must come from the SAME Firebase project: Console → Project settings → Your apps (Web).
#
# Production checklist if you see identitytoolkit.googleapis.com errors (400/403):
# 1. Authentication → Sign-in method → enable Email/Password.
# 2. Authentication → Settings → Authorized domains → add your real site (e.g. app.example.com).
# 3. Google Cloud → APIs & Services → Credentials → your Browser key:
#    - Do not restrict to wrong APIs; Identity Toolkit API must be usable from the web client.
#    - If using HTTP referrer restrictions, include your production origin(s).
# 4. Rebuild the frontend after changing any VITE_FIREBASE_* value.
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
