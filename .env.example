# API URL (required for production build)
VITE_API_URL=https://your-api.example.com/

# Dev only: uncomment so Vite proxies /api → local backend
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3001

# Super Admin: comma-separated emails get role superadmin on login
VITE_SUPERADMIN_EMAILS=superadmin@example.com

# Firebase Web Config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
